<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} %highlight{%-5level}{FATAL=red blink, ERROR=red, WARN=yellow bold, INFO=white, DEBUG=cyan, TRACE=blue} [%logger{36}] %msg%n%throwable" disableAnsi="false"/>
        </Console>
    </Appenders>

    <Loggers>
        <!-- Minestom internals: reduce noise from packet/network layers -->
        <Logger name="net.minestom.server.network" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- Voyager server -->
        <Logger name="net.elytrarace" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
